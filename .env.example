# Copy and rename per environment:
# - local machine: .env.local
# - staging VPS: /opt/guardgo-stage/.env.stage
# - production VPS: /opt/guardgo/.env.prod

# Public application URL settings
APP_URL='http://localhost:8080'
PRODUCTION='0'
PRODUCTION_DOMAIN='localhost'

# Core application secrets
S_SUPER_PASSWORD_V1='replace-with-a-long-random-admin-bootstrap-secret'
ENCRYPTION_KEY='replace-with-a-long-random-encryption-key'
S_CRAWLER_PASSWORD='replace-with-a-long-random-crawler-secret'

# Database and cache
MONGO_ROOT_USERNAME='guardgo'
MONGO_ROOT_PASSWORD='replace-with-a-long-random-mongo-password'
REDIS_PASSWORD='replace-with-a-long-random-redis-password'

# Demo and test users
DEMO_USERNAME='demo'
DEMO_PASSWORD='replace-with-a-demo-password-or-disable-demo-login'
CYPRESS_ADMIN_USERNAME='admin'
CYPRESS_ADMIN_PASSWORD='replace-with-a-non-production-test-password'

# Mail delivery
# Local Docker stack uses the bundled Mailpit service:
#   ACCOUNTS_SMTP_SERVER=mailpit
# Staging VPS with host-installed Mailpit should use:
#   ACCOUNTS_SMTP_SERVER=host.docker.internal
ACCOUNTS_MAIL='noreply@example.test'
ACCOUNTS_MAIL_PASSWORD='replace-with-smtp-password-or-anything-for-mailpit'
ACCOUNTS_SMTP_SERVER='mailpit'
ACCOUNTS_SMTP_PORT='1025'

# Feature/runtime flags
AUTH='1'
API_SWAGGER='1'
API_ACCESS='1'
SEMANTIC_ENABLED='1'
TESTING_ENABLED='0'

# Optional Google Maps support
GOOGLE_MAPS_API_KEY=''
GOOGLE_MAPS_MAP_ID=''
GOOGLE_MAPS_COUNTRY_RESTRICTION='ca'
GOOGLE_MAPS_GEOCODING_ENABLED='0'
GOOGLE_MAPS_DISTANCE_MATRIX_ENABLED='0'

# Optional Gunicorn tuning for stage/prod
GUNICORN_WORKERS='2'
GUNICORN_THREADS='2'
GUNICORN_TIMEOUT='180'
